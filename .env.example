# ============================================
# FRONTEND — /frontend/.env
# À créer dans le dossier /frontend
# ============================================

# Supabase (dashboard.supabase.com > Project Settings > API)
REACT_APP_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL de votre backend (Railway en production, localhost en développement)
REACT_APP_API_URL=http://localhost:3001

# Stripe Price IDs (dashboard.stripe.com > Products > Pack > Price ID)
REACT_APP_STRIPE_PRICE_STARTER=price_XXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_STRIPE_PRICE_STANDARD=price_XXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_STRIPE_PRICE_PRO=price_XXXXXXXXXXXXXXXXXXXXXXXX


# ============================================
# BACKEND — /backend/.env
# À créer dans le dossier /backend
# ============================================

PORT=3001

# Supabase — clé SERVICE (dashboard > Settings > API > service_role)
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI (platform.openai.com > API Keys)
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXX

# Stripe (dashboard.stripe.com > Developers > API Keys)
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# Stripe Price IDs (mêmes que frontend)
# Pack one-time (paiement unique)
STRIPE_PRICE_PACK=price_XXXXXXXXXXXXXXXXXXXXXXXX

# Abonnements annuels (mode=subscription dans Stripe)
STRIPE_PRICE_SOLO=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_PRO=price_XXXXXXXXXXXXXXXXXXXXXXXX

# URL de votre frontend Vercel
FRONTEND_URL=http://localhost:3000

# Google Vision API (reverse image search)
# Obtenir sur : console.cloud.google.com > APIs > Cloud Vision API
# Coût : ~0,001 € par image (1 500 images/mois gratuites)
GOOGLE_VISION_API_KEY=AIza...
